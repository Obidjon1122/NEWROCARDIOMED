                                    <property name="styleSheet">
                                     <string notr="true">/* 🔹 Oddiy holat */
#searchLineEdit {
    border: 2px solid #D1D1D1;
    border-radius: 10px;
    background: transparent;
    font-family: 'Inter';
    font-weight: 400;
    font-size: 18px;
    color: #444444;
    padding: 6px 10px;
    transition: all 0.2s ease-in-out;
}

/* 🔹 Fokusda (yozayotganda) */
#searchLineEdit:focus {
    border: 2px solid #3ccfc6;
    background: #f3fffd;
    font-family: 'Inter';
    font-weight: 500;
    font-size: 25px;
    color: rgb(0,0,0);
}
</string>
