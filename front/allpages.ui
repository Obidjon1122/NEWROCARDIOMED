    font-family: 'Inter';
    font-style: normal;
    font-weight: 800;
    font-size: 16px;
    line-height: 19px;
    color: #FFFFFF;
}

/* 🔹 Hover holati */
QPushButton:hover {
    background-color: #4CC5C0; /* biroz to‘qroq rang */
    color: #F0F0F0;           /* matn biroz ochroq */
    border: 2px solid #3AAFAA; /* ixtiyoriy effekt */
    transition: all 0.2s ease; /* silliq o‘tish */
}
</string>
