                              </property>
                              <property name="styleSheet">
                               <string notr="true">#mt_kontur_tri_ber {
border-radius: 8px;
background: #F9F9F9;
padding-left: 12px;
font-size: 18px;
}

#mt_kontur_tri_ber::drop-down {
width: 50px;
border-top-right-radius: 8px;
border-bottom-right-radius: 8px;
background: #F9F9F9;
border-left: none;
}

#mt_kontur_tri_ber::drop-down:hover {
background: #F9F9F9;
}

#mt_kontur_tri_ber::down-arrow {
image: url(:/icons/media/icons/down-arrow.png);
width: 16px;
height: 16px;
}

/* 🔽 Dropdown konteyner */
#mt_kontur_tri_ber QAbstractItemView {
background: #F9F9F9;
border: 1px solid #E0E0E0;
border-radius: 8px;
outline: none;
selection-background-color: #E8F5E9;
selection-color: #000;
padding: 4px;
}

/* 🔹 Har bir item */
#mt_kontur_tri_ber QAbstractItemView::item {
padding-left: 12px;
padding-right: 12px;
font-size: 18px;
color: #000;
border-radius: 6px;
margin: 2px 0px;
}

/* 🔹 Hover */
#mt_kontur_tri_ber QAbstractItemView::item:hover {
background-color: #F1F8F4;
}

/* 🔹 Selected */
#mt_kontur_tri_ber QAbstractItemView::item:selected {
background-color: #E8F5E9;
color: #000;
}</string>
