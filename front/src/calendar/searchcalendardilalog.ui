         <widget class="QCalendarWidget" name="calendarWidget">
          <property name="styleSheet">
           <string notr="true">/*CALENDAR*/
QCalendarWidget {
	font-size: 18px;
}

QCalendarWidget QToolButton {
	height: 36px;
	font-size: 18px;
	background-color: rgb(0, 0, 0, 0);
	margin: 5px;
}

QCalendarWidget QWidget#qt_calendar_navigationbar {
	background-color: rgb(0, 0, 0, 0);
	border: 1px solid rgb(0, 0, 0, 13);
	border-top-left-radius: 5px;
	border-top-right-radius: 5px;
	border-bottom-left-radius: 0px;
	border-bottom-right-radius: 0px;
	border-bottom: none;
}

QCalendarWidget QMenu {
	background-color: #f3f3f3;
	font-size: 20px;
	padding: 5px;
}

QCalendarWidget QMenu::item {
	padding: 10px 20px;
	font-size: 20px;
	font-weight: 500;
}

QCalendarWidget QMenu::item:selected {
	background-color: #69DFD9;
	color: #FFFFFF;
	border-radius: 5px;
}

#qt_calendar_prevmonth {
	qproperty-icon: url(:/icons/media/icons/PrevMonth.png);
	width: 32px;
}

#qt_calendar_nextmonth {
	qproperty-icon: url(:/icons/media/icons/NextMonth.png);
	width: 32px;
}

#qt_calendar_prevmonth:hover, #qt_calendar_nextmonth:hover {
	background-color: #69DFD9;
	border-radius: 5px;
}

#qt_calendar_prevmonth:pressed, #qt_calendar_nextmonth:pressed {
	background-color: #5BC9C3;
	border-radius: 5px;
}

#qt_calendar_yearbutton, #qt_calendar_monthbutton {
	color: rgb(0, 0, 0);
	margin: 5px 0px;
	padding: 0px 10px;
}

#qt_calendar_yearbutton:hover, #qt_calendar_monthbutton:hover {
	background-color: #69DFD9;
	color: #FFFFFF;
	border-radius: 5px;
}

#qt_calendar_yearbutton:pressed, #qt_calendar_monthbutton:pressed {
	background-color: #5BC9C3;
	color: #FFFFFF;
	border-radius: 5px;
}

QCalendarWidget QToolButton::menu-indicator#qt_calendar_monthbutton {
	background-color: transparent;
}

/* SpinBox umumiy stil */
QCalendarWidget QSpinBox {
	margin: 5px;
	background-color: rgba(255, 255, 255, 0.5);
	border: 1px solid rgba(0, 0, 0, 0.15);
	border-radius: 8px;
	padding: 5px 35px 5px 10px;
	font-size: 18px;
	font-weight: 500;
	color: rgb(0, 0, 0);
	min-height: 32px;
}

QCalendarWidget QSpinBox:hover {
	background-color: rgba(255, 255, 255, 0.8);
	border: 1px solid rgba(105, 223, 217, 0.5);
}

QCalendarWidget QSpinBox:focus {
	background-color: rgba(255, 255, 255, 0.9);
	border: 2px solid #69DFD9;
	color: rgb(0, 0, 0);
}

/* Yuqoriga strelka */
QCalendarWidget QSpinBox::up-button {
	image: url(:/icons/media/icons/SpinBoxUp.png);
	background-color: transparent;
	border: none;
	border-radius: 4px;
	width: 28px;
	height: 16px;
	subcontrol-origin: border;
	subcontrol-position: top right;
	right: 3px;
	top: 2px;
}

QCalendarWidget QSpinBox::up-button:hover {
	background-color: #69DFD9;
}

QCalendarWidget QSpinBox::up-button:pressed {
	background-color: #5BC9C3;
}

/* Pastga strelka */
QCalendarWidget QSpinBox::down-button {
	image: url(:/icons/media/icons/SpinBoxDown.png);
	background-color: transparent;
	border: none;
	border-radius: 4px;
	width: 28px;
	height: 16px;
	subcontrol-origin: border;
	subcontrol-position: bottom right;
	right: 3px;
	bottom: 2px;
}

QCalendarWidget QSpinBox::down-button:hover {
	background-color: #69DFD9;
}

QCalendarWidget QSpinBox::down-button:pressed {
	background-color: #5BC9C3;
}

QCalendarWidget QWidget {
	alternate-background-color: rgb(0, 0, 0, 0);
}

/* Hafta kunlari header (Du, Se, Chor...) - HOVER YO'Q */
QCalendarWidget QHeaderView::section {
	background-color: transparent;
	color: rgb(0, 0, 0);
	padding: 8px;
	font-size: 18px;
	font-weight: 600;
	border: none;
	pointer-events: none;
}

/* Kunlar (sanalar) */
QCalendarWidget QAbstractItemView {
	font-size: 18px;
	font-weight: 500;
}

QCalendarWidget QAbstractItemView:enabled {
	color: rgb(0, 0, 0);
	selection-background-color: rgba(105, 223, 217, 0.3);
	selection-color: rgb(0, 0, 0);
	border: 1px solid rgb(0, 0, 0, 10);
	border-top-left-radius: 0px;
	border-top-right-radius: 0px;
	border-bottom-left-radius: 5px;
	border-bottom-right-radius: 5px;
	outline: 0;
}

/* Barcha kunlar uchun hover - bugungi kun ham */
QCalendarWidget QTableView::item:hover {
	background-color: #69DFD9;
	color: white;
	border-radius: 5px;
}

/* Tanlangan kun (bugungi kun) */
QCalendarWidget QTableView::item:selected {
	background-color: rgba(105, 223, 217, 0.3);
	color: rgb(0, 0, 0);
	border-radius: 5px;
}

/* Tanlangan kun ustiga hover */
QCalendarWidget QTableView::item:selected:hover {
	background-color: #69DFD9;
	color: white;
	border-radius: 5px;
}

QCalendarWidget QAbstractItemView:disabled {
	color: rgb(30, 30, 30);
	selection-background-color: rgb(30, 30, 30);
	selection-color: black;
	border: 1px solid rgb(0, 0, 0, 13);
	border-top-left-radius: 0px;
	border-top-right-radius: 0px;
	border-bottom-left-radius: 5px;
	border-bottom-right-radius: 5px;
}

#qt_calendar_yearbutton:disabled, #qt_calendar_monthbutton:disabled {
	color: rgb(0, 0, 0, 110);
}

#qt_calendar_prevmonth:disabled {
	qproperty-icon: url(:/icons/media/icons/PrevMonth.png);
}

#qt_calendar_nextmonth:disabled {
	qproperty-icon: url(:/icons/media/icons/NextMonth.png);
}</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
