#comboBoxClientRegion::down-arrow {
    image: url(:/icons/media/icons/comboboxArrowImage.png);
    width: 24px;
    height: 24px;
}

/* 🔽 Dropdown konteyner */
#comboBoxClientRegion QAbstractItemView {
    background: #F9F9F9;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    outline: none;
    width: 560px; /* ComboBox'dan 8px kichikroq (padding uchun) */
    selection-background-color: #E8F5E9;
    selection-color: #000;
    padding: 4px;
}

/* 🔹 Har bir item aniq o'lcham */
#comboBoxClientRegion QAbstractItemView::item {
    height: 48px; /* ComboBox'dan 4px kichikroq */
    min-height: 48px;
    max-height: 48px;
    width: 548px; /* Container ichida to'liq joy egallash */
    padding-left: 12px;
    padding-right: 12px;
    font-size: 16px;
    color: #000;
    border-radius: 6px;
    margin: 2px 0px;
}

#comboBoxClientRegion::down-arrow:on, 
#comboBoxClientRegion::up-arrow, 
#comboBoxClientRegion::up-arrow:on {
    image: none;
}

/* 🔹 Hover */
#comboBoxClientRegion QAbstractItemView::item:hover {
    background-color: #F1F8F4;
}

/* 🔹 Selected */
#comboBoxClientRegion QAbstractItemView::item:selected {
    background-color: #E8F5E9;
    color: #000;
}

/* ❌ Scroll buttonlarni butunlay yo'qotish */
#comboBoxClientRegion QAbstractItemView QScrollBar::sub-line:vertical,
#comboBoxClientRegion QAbstractItemView QScrollBar::add-line:vertical {
    height: 0px;
    width: 0px;
    background: none;
    border: none;
}

#comboBoxClientRegion QAbstractItemView QScrollBar::up-arrow:vertical,
#comboBoxClientRegion QAbstractItemView QScrollBar::down-arrow:vertical {
    width: 0px;
    height: 0px;
    background: none;
}

/* 🔹 Scroll barni ham sozlash */
#comboBoxClientRegion QAbstractItemView QScrollBar:vertical {
    width: 8px;
    background: transparent;
    margin: 0px;
}

#comboBoxClientRegion QAbstractItemView QScrollBar::handle:vertical {
    background: #BDBDBD;
    border-radius: 4px;
    min-height: 30px;
}</string>
