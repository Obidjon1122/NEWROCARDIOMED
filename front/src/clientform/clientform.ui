           <property name="styleSheet">
            <string notr="true">#pushButtonCreateClient {
    position: absolute;
    width: 130px;
    height: 45px;
    left: 797px;
    top: 814px;

    font-family: 'Inter';
    font-style: normal;
    font-weight: 800;
    font-size: 20px;
    line-height: 19px;
    color: #5C5C5C;

    background: #FFFFFF;
    border: 1px solid #CCCCCC;
    border-radius: 10px;

    /* Silliq o‘tish effekti */
    transition: background-color 0.2s ease, color 0.2s ease;
}

/* Hover — ustiga olib borganda */
#pushButtonCreateClient:hover {
    background-color: #F2F2F2;
}

/* Pressed — bosilganda */
#pushButtonCreateClient:pressed {
    background-color: #69DFD9;
    color: white; /* ixtiyoriy: bosilganda yozuv oq bo‘ladi */
}</string>
