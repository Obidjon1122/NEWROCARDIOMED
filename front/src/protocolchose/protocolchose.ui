        <property name="styleSheet">
         <string notr="true">#pushButtonQuit1 {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 800;
    font-size: 16px;
    line-height: 19px;
    color: white;
    background: transparent; /* fon shaffof */
    border: none;             /* ramkasiz */
    transition: color 0.2s ease;
}

/* Pressed (bosilganda) — yanada to‘q qizil bo‘ladi */
#pushButtonQuit1:pressed {
    color: #CC0000;
}</string>
