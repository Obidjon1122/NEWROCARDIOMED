           <property name="styleSheet">
            <string notr="true">QPushButton#MashonkaButton {
	text-align:center;
    background-color: #FFFFFF;
    border-radius: 15px;
    width: 105px;
    height: 35px;
    border: 1px solid #CCCCCC;
    font-family: 'Inter';
    font-style: normal;
    font-weight: 800;
    font-size: 16px;
    line-height: 19px;
    color: #000000;
}

/* Hover holati */
QPushButton#MashonkaButton:hover {
    background-color: #F2F2F2;
}

/* Bosilganda (pressed holatida) */
QPushButton#MashonkaButton:pressed {
    background-color: #69DFD9;
}

/* Disabled holat (ixtiyoriy, chiroyli ko'rinish uchun) */
QPushButton#MashonkaButton:disabled {
    background-color: #F8F8F8;
    color: #A0A0A0;
    border: 1px solid #E0E0E0;
}
</string>
